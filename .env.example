# OracleVision Environment Variables
# Copy this file to .env and fill in your values

# Application
DEBUG=false
APP_NAME=OracleVision

# Database
DATABASE_URL=sqlite:///./oraclevision.db

# Oracle Client (optional - for thick mode)
# ORACLE_CLIENT_PATH=/path/to/oracle/client

# AI/LLM Settings
OPENAI_API_KEY=your-openai-api-key
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview

# Alternative LLM (Anthropic)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-sonnet-20240229

# Embedding Settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Vector DB
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=./chroma_db

# Security
JWT_SECRET_KEY=change-this-to-a-random-secret-key
ENCRYPTION_KEY=generate-a-32-byte-key
