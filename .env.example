# OracleVision Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Database Configuration
# ===========================================

# Oracle Database
ORACLE_HOST=oracle-xe
ORACLE_PORT=1521
ORACLE_SERVICE=XEPDB1
ORACLE_USER=oraclevision
ORACLE_PASSWORD=vision123

# PostgreSQL (for vector storage)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=oracle_vision
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ===========================================
# Security Configuration
# ===========================================

# JWT Settings (change this in production!)
SECRET_KEY=change-me-in-production-use-strong-random-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================
# LLM / AI Configuration
# ===========================================

# OpenAI API Key (required for text-to-SQL)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key (optional alternative)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Ollama (local LLM - optional)
OLLAMA_BASE_URL=http://localhost:11434

# Default LLM Provider: openai, anthropic, or ollama
DEFAULT_LLM_PROVIDER=openai

# ===========================================
# Application Settings
# ===========================================

# Debug mode (set to false in production)
DEBUG=false

# Application name
APP_NAME=OracleVision
